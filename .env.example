# ============================================
# Root .env (AmenityGap-NYC/.env)
# Used by the backend and ETL scripts
# Create in repo's root directory
# Ignore this if you are not an active contributor
# ============================================
SUPABASE_URL=your-url-here
SUPABASE_KEY=your-key-here
# No longer needed since backend is no longer called by frontend. Supabase directly queried.

# ============================================
# Frontend .env (AmenityGap-NYC/frontend/amenitygap-app/.env)
# Used by the Vite frontend for Mapbox
# Create a separate .env file in /amenitygap-app/
# Create a free account at https://account.mapbox.com/ and copy your default public token
# For supabase url/key email dglum.
# ============================================
VITE_MAPBOX_TOKEN=your-token-here
VITE_SUPABASE_URL=your-url-here
VITE_SUPABASE_ANON_KEY=your-key-here